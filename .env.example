# Telegram
TELEGRAM_TOKEN=your_token_here
TELEGRAM_CHAT_ID=-5013191013
SERVER_NAME=vector22322

# Пороги RAM одного процесса (%)
RAM_PROCESS_WARN=5
RAM_PROCESS_CRIT=15

# Пороги общей RAM системы (%)
RAM_TOTAL_WARN=75
RAM_TOTAL_CRIT=90

# Пороги CPU одного процесса (%)
CPU_PROCESS_WARN=50
CPU_PROCESS_CRIT=80

# Антиспам — повторный алерт не чаще X минут
REPEAT_ALERT_MIN=30

# Интервал проверки в минутах
CHECK_INTERVAL_MIN=2

# Файл состояния алертов
STATE_FILE=/app/data/monitor_state.json

# Список admin Telegram user_id через запятую
ADMIN_IDS=your_id1,your_id2

# Минимальный суммарный RAM дублей для алерта (MB)
DUPLICATE_MIN_RAM_MB=50
